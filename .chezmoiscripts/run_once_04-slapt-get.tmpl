{{ if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "slackware") -}}
#!/bin/bash
echo -e "\n\033[1m━━━  slapt-getrc  ━━━\033[0m"
if sudo cp -iv $HOME/.local/share/chezmoi/slapt-getrc /etc/slapt-get/slapt-getrc; then
  echo -e "\033[0;32m\033[1m[OK]\033[0m    slapt-getrc copied successfully"
else
  echo -e "\033[1m[ERROR]\033[0m Failed to copy slapt-getrc" >&2;
fi
{{ end -}}
