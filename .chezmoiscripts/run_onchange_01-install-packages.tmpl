{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

echo -e "\n\033[1m━━━  Package installation  ━━━\033[0m";

{{ $distro := includeTemplate "distro.tmpl" . -}}

echo -e "\033[0;36m\033[1m[INFO]\033[0m  Detected distro family: {{ $distro }}";

{{ $distroPackages := index .packages $distro -}}

{{ if eq $distro "arch" -}}

{{- $aurHelper := "pacman -S --needed" -}}
{{- if lookPath "yay" -}}
  {{- $aurHelper = "yay -S --needed" -}}
{{- else if lookPath "paru" -}}
  {{- $aurHelper = "paru" -}}
{{- end -}}

echo -e "\033[0;36m\033[1m[INFO]\033[0m  Using AUR helper: {{ $aurHelper }}";

sudo {{ $aurHelper }} {{ .packages.linux | join " " }} {{ $distroPackages | join " " -}};

echo -e "\033[0;32m\033[1m[OK]\033[0m    Package installation complete.";
{{- else if eq $distro "debian" "ubuntu" "kali" }}
sudo apt install {{ .packages.linux | join " " }} {{ $distroPackages | join " " -}};
echo -e "\033[0;32m\033[1m[OK]\033[0m    Package installation complete.";
{{- else if eq $distro "fedora" }}
# TODO
{{- else }}
  echo -e "\033[1m[ERROR]\033[0m Unsupported distro. Please install packages manually: {{ .packages.linux | join " " }}" >&2;
{{- end }}

ZSH_LOC=$(which zsh)
if [[ -f $ZSH_LOC && $SHELL != *zsh*  ]]; then
echo -e "\033[0;36m\033[1m[INFO]\033[0m  Default shell is not zsh, changing shell";
chsh -s $ZSH_LOC
fi

{{ else if eq .chezmoi.os "darwin" -}}
#!/bin/bash
brew install ripgrep
{{ end -}}
