{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

echo -e "\n\033[1m━━━  nnn plugins  ━━━\033[0m"
if [[ -d "${XDG_CONFIG_HOME:-$HOME/.config}/nnn/plugins" ]]; then
  echo -e "\033[0;36m\033[1m[INFO]\033[0m  nnn plugins directory already exists — re-running getplugs to update …"
fi

yes o | sh -c "$(curl -Ls https://raw.githubusercontent.com/jarun/nnn/master/plugins/getplugs)"
if [[ $? -eq 0 ]]; then
echo -e "\033[0;32m\033[1m[OK]\033[0m    nnn plugins installed to ${XDG_CONFIG_HOME:-$HOME/.config}/nnn/plugins"
fi
{{ end -}}
