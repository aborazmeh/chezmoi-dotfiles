opts, args = getopt.getopt(sys.argv[1:], "Ll:dw:di")

apikey = "{{ .forvo.api_key }}"
language, word, langname = '', '', ''

if not os.path.exists(("/tmp/myforvo")):
    os.mkdir("/tmp/myforvo")

list = False
for o, a in opts:
    if o in ("-l", "--language="):
        language = a.lower()
    elif o in ("-w", "--word="):
        word = a.lower()
    elif o in ("-L"):
        list = True

if not word:
    sys.exit(1)


if list:
    if not os.path.isfile("/tmp/myforvo/" + word + "-list.txt") or os.stat("/tmp/myforvo/" + word + "-list.txt").st_size <= 0:
        # List languages
        languages_list = []
        url = 'http://apifree.forvo.com/key/'+apikey+'/format/xml/action/word-pronunciations/word/' + word
        http = urllib3.PoolManager(timeout=3.0)
        respond = http.request('GET', url)
        tree = BeautifulSoup(respond.data)
        respond.release_conn()
        for l in tree.find_all('langname'):
            if l.text not in languages_list:
                languages_list.append(l.text)
        # Print the languages with ISO639_1 codes:
        listfile = open("/tmp/myforvo/" + word + "-list.txt", "w")
        for l in languages_list:
            for k,v in ISO639_1.items():
                if v == l:
                    listfile.write(k +":" + l + "\n")
        listfile.close()
    listfile = open("/tmp/myforvo/" + word + "-list.txt", "r")
    print(listfile.read())

else:
    if not language: language = "std"
    if not os.path.isfile("/tmp/myforvo/" + language + ":" + word + ".mp3") or os.stat("/tmp/myforvo/" + language + ":" + word + ".mp3").st_size <= 0:
        url = 'http://apifree.forvo.com/key/' + apikey + '/format/xml/action/standard-pronunciation/word/' + word
        if language:
            url +=  '/language/' + language
        http = urllib3.PoolManager(timeout=3.0)
        respond = http.request('GET', url)
        tree = BeautifulSoup(respond.data)
        respond.release_conn()
        mp3, ogg = tree.find('pathmp3').text, tree.find('pathogg').text
        langname = tree.find('langname').text

        url = mp3
        http = urllib3.PoolManager(timeout=3.0)
        respond = http.request('GET', url)
        mp3_file = open("/tmp/myforvo/" + language + ":" + word + ".mp3", 'wb')
        mp3_file.write(respond.data)
        respond.release_conn()

    #song = pyglet.media.load("/tmp/myforvo/" + language + ":" + word + ".mp3")
    #song.play()
    #pyglet.app.run()
    #sys.exit(0)
    #os.popen("play " + "/tmp/myforvo/" + language + ":" + word + ".mp3")
    if langname or language != "std":
        print("Word: ", word, "\nLanguage: ", langname or ISO639_1[language])
    else:
        print("Word: ", word)

    p = Popen(["mpg123", "/tmp/myforvo/" + language + ":" + word + ".mp3"])
