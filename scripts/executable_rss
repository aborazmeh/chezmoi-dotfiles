#!/bin/bash

[[ -f $HOME/.silent_mode ]] && exit

DB=$HOME/.newsbeuter/cache.db

sqlite3 "$DB" "PRAGMA query_only = 1; PRAGMA temp_store = MEMORY;"

readarray -t feed_counts < <(sqlite3 -separator '|' "$DB" "
  SELECT feedurl, COUNT(*)
  FROM rss_item
  WHERE unread = 1
  GROUP BY feedurl
")

mapfile -t urls < <(grep -E '^http' $HOME/.newsbeuter/urls | grep -v 'podcast' | grep -v '^#' | grep -v '^$' | sed 's/ .*//')

declare -A url_count
for count_line in "${feed_counts[@]}"; do
  [[ -z $count_line ]] && continue
  url="${count_line%|*}"
  count="${count_line#*|}"
  url_count["$url"]="$count"
done

unread_count=0
for u in "${urls[@]}"; do
  unread_count=$((unread_count + ${url_count[$u]:-0}))
done

html_escape() {
  local str="$1"
  str="${str//&/&amp;}"
  str="${str//</&lt;}"
  str="${str//>/&gt;}"
  str="${str//\"/&quot;}"
  str="${str//\'/&#39;}"
  printf "%s" "$str"
}

list() {
  local query="SELECT title FROM rss_item WHERE unread = 1 ORDER BY pubDate DESC LIMIT 20;"
  local result
  result=$(sqlite3 "$DB" "$query" 2>/dev/null)
  if [[ -n "$result" ]]; then
    local escaped=""
    while IFS= read -r line; do
      [[ -z "$escaped" ]] && escaped="$(html_escape "$line")" || escaped+=$'\n'"$(html_escape "$line")"
    done <<<"$result"
    printf "%s" "$escaped"
  fi
}

notify() {
  notify-send "  RSS Feeds" "$(list)"
}

# case $BLOCK_BUTTON in
# 1 ) notify-send "$(sqlite3 ~/.newsbeuter/cache.db "SELECT title FROM rss_item WHERE unread = 1 ORDER BY pubDate ASC LIMIT 30")" ;;
# esac

if [[ $unread_count -gt 0 ]]; then
  case "${1:-}" in
  i3blocks)
    echo " ($unread_count)"
    echo "#f26522"
    [[ $BLOCK_BUTTON -eq 1 ]] && notify
    ;;
  polybar)
    echo "%{F#f26522} ($unread_count)%{F-}"
    ;;
  waybar)
    jq -n --arg count "$unread_count" --arg tooltip "$(list | sed 's/\\n$//')" \
      '{text: $count, tooltip: $tooltip}' --compact-output
    ;;
  notify)
    notify
    ;;
  esac
fi
