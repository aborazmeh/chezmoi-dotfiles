#!/bin/bash

[[ -f ~/.silent_mode ]] && exit

DB=~/.newsbeuter/cache.db

sqlite3 "$DB" "PRAGMA query_only = 1; PRAGMA temp_store = MEMORY;"

mapfile -t urls < <(grep -E '^http.* .*podcast' ~/.newsbeuter/urls | awk '{print $1}')

[[ ${#urls[@]} -eq 0 ]] && exit 0

url_list=""
for u in "${urls[@]}"; do
  u_escaped="${u//\'/\'\'}"
  [[ -n "$url_list" ]] && url_list+=","
  url_list+="'$u_escaped'"
done

unread_count=$(sqlite3 "$DB" "
  SELECT COUNT(*)
  FROM rss_item
  WHERE unread = 1
  AND feedurl IN ($url_list)
" 2>/dev/null)
[[ -z $unread_count ]] && unread_count=0

html_escape() {
  local str="$1"
  str="${str//&/&amp;}"
  str="${str//</&lt;}"
  str="${str//>/&gt;}"
  str="${str//\"/&quot;}"
  str="${str//\'/&#39;}"
  printf "%s" "$str"
}

list() {
  local query="SELECT title FROM rss_item
    WHERE unread = 1
    AND feedurl IN ($url_list)
    ORDER BY pubDate DESC
    LIMIT 20;"

  local result
  result=$(sqlite3 "$DB" "$query" 2>/dev/null)

  if [[ -n "$result" ]]; then
    local escaped=""
    while IFS= read -r line; do
      [[ -z "$escaped" ]] && escaped="$(html_escape "$line")" || escaped+=$'\n'"$(html_escape "$line")"
    done <<<"$result"
    printf "%s" "$escaped"
  fi
}

notify() {
  notify-send " Podcasts" "$(list)"
}

if [[ $unread_count -gt 0 ]]; then
  case "${1:-}" in
  i3blocks)
    echo " ($unread_count)"
    echo "#a26eea"
    [[ $BLOCK_BUTTON -eq 1 ]] && notify
    ;;
  polybar)
    echo "%{F#a26eea} ($unread_count)%{F-}"
    ;;
  waybar)
    jq -n --arg count "$unread_count" --arg tooltip "$(list | sed 's/\\n$//')" \
      '{text: $count, tooltip: $tooltip}' --compact-output
    ;;
  notify)
    notify
    ;;
  esac
fi
