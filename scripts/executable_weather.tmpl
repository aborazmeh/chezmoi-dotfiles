res = requests.get('https://en.wttr.in/{{ .city }}?format=j1')
data = json.loads(res.text)

weatherCode = data['current_condition'][0]['weatherCode']
weatherDesc = WWO_CODE[weatherCode]

icon = WEATHER_SYMBOL.get(weatherDesc) if WEATHER_SYMBOL.get(weatherDesc) else WEATHER_SYMBOL['Unknown']
color = WEATHER_COLOR.get(weatherDesc) if WEATHER_COLOR.get(weatherDesc) else WEATHER_COLOR['Unknown']

temperature = data['current_condition'][0]['temp_C']

tooltip = ''
most_frequent = lambda List: max(set(List), key = List.count)
for w in data['weather']:
  w_weatherCode = most_frequent(list(map(lambda x: x['weatherCode'], w['hourly'])))
  w_weatherDesc = WWO_CODE[w_weatherCode]
  w_icon = WEATHER_SYMBOL.get(w_weatherDesc) if WEATHER_SYMBOL.get(w_weatherDesc) else WEATHER_SYMBOL['Unknown']
  tooltip += f"{w['date']}\t{w_icon} {w['avgtempC']}℃\n"

if len(sys.argv) < 2:
  print(f'{icon}  {temperature}', end='')
  exit()

if sys.argv[1] == 'notify':
#     notify-send "$(date +'%A, %F')" "$weather"
  pass
elif sys.argv[1] == "i3blocks":
  print(f'<span foreground="{color}">{icon}  {temperature}</span>', end='')
elif sys.argv[1] == 'waybar':
    print(
      json.dumps({
      'text': f'{icon}  {temperature}℃',
      'tooltip': tooltip.strip(),
      'class': weatherDesc.lower()
      },
      ensure_ascii=False,
      separators= (',', ':')
      )
    )
