{
  "layer": "top",
  "position": "top",
  "modules-left": ["sway/mode", "wlr/workspaces"],
  "modules-center": ["sway/window"],
  "modules-right": ["custom/music", "mpd", "custom/torrents", "custom/rss", "custom/podcasts", "custom/torn"],
  "wlr/workspaces": {
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "disable-scroll-wraparound": false,
    "smooth-scrolling-threshold": 1,
    "enable-bar-scroll": true,
    "format": "{icon}",
    "format-icons": {
      "1": "’äĀ",
      "2": "’äĪ",
      "3": "’ē®",
      "4": "’ģ£",
      "5": "’ĆŁ",
      "6": "’ü╝",
      "7": "’äł",
      "8": "’ģ╝",
      "9": "’ā”",
      "10": "’ĆĮ",
      "urgent": "’ü¬",
      "focused": "’åÆ",
      "default": "’äæ"
    }
  },
  "custom/music": {
    "exec": "~/scripts/music -f sway",
    "interval": 1,
    "return-type": "json",
    "on-click": "~/scripts/music -f sway toggle",
    "on-click-right": "~/scripts/music -f sway stop",
    "on-scroll-up": "~/scripts/music -f sway seek+",
    "on-scroll-down": "~/scripts/music -f sway seek-",
    "on-click-middle": "~/scripts/music -f sway bookmark",
  },
  "mpd": {
    "server": "localhost",
    "port": "6680",
    "interval": 1,
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}({elapsedTime:%H:%M:%S}/{totalTime:%H:%M:%S}){title}",
    "format-stopped": "",
    "format-disconnected": "",
    "tooltip-format": "{author}, {title} [{album}]",
    "tooltip-format-disconnected": "",
    "max-length": 60,
    "on-click": "mpc toggle",
    "on-click-right": "mpc seek -10",
    "on-scrool-up": "mpc seek +10",
    "on-scrool-down": "mpc seek -10",
    "consume-icons": {
      "on": "’āä "
    },
    "random-icons": {
      "off": "",
      "on": "’ü┤ "
    },
    "repeat-icons": {
      "on": "’Ć× "
    },
    "single-icons": {
      "on": "’Ć×1 "
    },
    "state-icons": {
      "paused": "’üī",
      "playing": "’üŗ"
    }
  },
  "custom/torrents": {
    "interval" : 1,
    "format": "’üČ {}",
    "return-type": "json",
    "tooltip": true,
    "on-click": "$HOME/scripts/i3blocks/qbittorrents -c alt-speed-limits",
    "exec": "$HOME/scripts/i3blocks/qbittorrents -jf waybar"
  },
  "custom/podcasts": {
    "interval" : 60,
    "format": "’ŗÄ {}",
    "return-type": "json",
    "tooltip": true,
    "exec": "$HOME/scripts/podcasts waybar",
    "on-click": "konsole -e newsboat"
  },
  "custom/rss": {
    "interval" : 60,
    "format": "’é× {}",
    "return-type": "json",
    "tooltip": true,
    "exec": "$HOME/scripts/rss waybar",
    "on-click": "konsole -e newsboat"
  },
  "custom/torn": {
    "interval" : 1,
    "format": "{}",
    "return-type": "json",
    "tooltip": true,
    "on-click": "$HOME/scripts/torn --open",
    "exec": "$HOME/scripts/torn --json --emoji --bar waybar"
  },
