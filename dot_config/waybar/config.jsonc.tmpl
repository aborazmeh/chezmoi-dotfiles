{
  "layer": "top",
  "position": "bottom",
  "modules-left": [ {{ if eq .chassis_type "laptop" -}} "backlight", "battery", {{- end }} "pulseaudio", "cpu", "temperature", "memory", "disk", "network" {{- if eq .machine "home" -}}, "custom/exchange", "custom/weather" {{- end }} ],
  "modules-center": [ "custom/clock" {{- if eq .machine "home" }}, "custom/praytimes" {{- end }} ],
  "modules-right": [ "tray", "keyboard-state" {{- if eq .machine "home" }}, "custom/keyboard" {{- else }}, "sway/language" {{- end }} {{- if eq .chassis_type "laptop" }}, "bluetooth" {{- end }} ],
  "clock": {
    "interval": 60,
    "format": "яАЧ {:%H:%M}",
    "timezone": "{{ .timezone }}",
    "tooltip-format": "{:%Y-%m-%d}"
  },
  "custom/clock": {
    "interval": 60,
    "format": "яАЧ  {}",
    "return-type": "json",
    "exec": "$HOME/scripts/bar/date -f waybar",
    "on-click": "$HOME/scripts/bar/date -f waybar -c"
  },
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": {
      "numlock": "[N]",
      "capslock": "[C]"
    },
    "format-icons": {
      "locked": "яАг",
      "unlocked": "яВЬ"
    }
  },
  "sway/language": {
    "format": "{flag} {long}",
    "tooltip": false,
    "return-type": "json",
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    "on-click-right": "swaymsg input '*' xkb_switch_layout prev",
    "on-scroll-up": "swaymsg input '*' xkb_switch_layout next",
    "on-scroll-down": "swaymsg input '*' xkb_switch_layout prev"
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "bluetooth": {
    "format": "",
    "format-on": "яКФ {status}",
    "format-off": "",
    "format-disabled": "", // an empty format will hide the module
    "format-connected": "яКФ {device_alias}",
    "format-connected-battery": "яКФ {device_alias} {device_battery_percentage}%",
    // "format-device-preference": [ "device1", "device2" ], // preference list deciding the displayed device
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "ghostty --command=bluetoothctl"
  },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{icon}",
    "states": [ 0, 50 ],
    "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
    "on-scroll-up": "light -A 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob",
    "on-scroll-down": "light -U 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob",

    "on-click": "killall wlsunset ; swaymsg exec 'wlsunset -l {{ .latitude }} -L {{ .longitude }}'",
    "on-click-right": "killall wlsunset",
    "on-click-middle": "darkman toggle",
  },
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },
  "custom/keyboard": {
    "format": "{}",
    "tooltip": true,
    "return-type": "json",
    "exec": "$HOME/scripts/bar/kbd_layouts_i3ipc",
    "on-click": "swaymsg input '*' xkb_switch_layout next",
    "on-click-right": "swaymsg input '*' xkb_switch_layout prev",
    "on-scroll-up": "swaymsg input '*' xkb_switch_layout next",
    "on-scroll-down": "swaymsg input '*' xkb_switch_layout prev"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-bluetooth": " яКФ{icon} {volume}%",
    "format-muted": "яАж",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАз", "яАи"]
    },
    {{ $m := printf "%s/scripts/bar/music" .chezmoi.homeDir | lstat -}}
    "on-click": "{{ or (and $m "$HOME/scripts/bar/music -f sway mute") "amixer -D pulse set Master toggle" }}",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "{{ or (and $m "$HOME/scripts/bar/music -f sway volume+") "amixer -D pulse set Master unmute 5%+" }}",
    "on-scroll-down": "{{ or (and $m "$HOME/scripts/bar/music -f sway volume-") "amixer -D pulse set Master unmute 5%-" }}"
  },
  "cpu": {
    "format": "яЛЫ  {usage}%",
    "on-click": "cpupower-gui"
  },
  "memory": {
    "format": "ґ░НЫ {}%",
    "on-click": "ghostty --command=btop",
  },
  "temperature": {
    // "thermal-zone": 2,
    // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    // "format-critical": "{temperatureC}┬░C яЛЗ",
    "format": "яЛЙ {temperatureC}┬░C",
    "on-click": "ghostty --command=btop",
  },
  "disk": {
    "format": " яВа  {percentage_used}% ",
    "path": "/",
    "tooltip-format": "{free} remaining of {total} on `/` [{percentage_used}%]",
    "on-click": "ghostty --command=ncdu",
    "on-click-middle": "ghostty --command=yazi",
    "on-click-right": "ghostty --command=nnn",
  },
  "network": {
    "format": "{ifname}",
    "interface": "{{ .network_interface }}",
    "format-wifi": "яЗл   {signalStrength}% яВл   {bandwidthDownOctets} яВк   {bandwidthUpOctets}",
    "format-ethernet": "яГБ  яВл {bandwidthDownOctets} яВк {bandwidthUpOctets}",
    "format-disconnected": "яБ▒",

    "tooltip" : true,
    "tooltip-format": "{ifname}",
    "tooltip-format-wifi": "{ipaddr}\n{essid} ({signalStrength}%) яЗл",
    "tooltip-format-ethernet": "{ifname} яГБ",
    "tooltip-format-disconnected": "Disconnected",

    "interval" : 3,
    "on-click": "ghostty --command=nmtui"
  },
  "custom/exchange": {
    "interval": 5,
    "format": "{icon}   {}",
    "format-icons": {
      "default": "яГЦ"
    },
    "tooltip": true,
    "return-type": "json",
    "exec": "$HOME/scripts/bar/exchange USDTRY EURTRY USDSYP TRYSYP --json 2> /dev/null"
  },
  "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "return-type": "json",
    "exec": "$HOME/scripts/weather waybar 2> /dev/null",
    "interval": 600
  },
  "custom/praytimes" : {
    "format": "ЁЯХМ {}",
    "return-type": "json",
    "tooltip": "true",
    "exec": "$HOME/scripts/prayertimes -jf waybar 2> /dev/null",
    "interval": 10
  }

}
