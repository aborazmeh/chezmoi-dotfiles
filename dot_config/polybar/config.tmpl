[theme]
; background = ${xrdb:color0:#222}
background = #333
background-alt = #444
; foreground = ${xrdb:color7:#222}
foreground = #dfdfdf
foreground-alt = #555
primary = #ffb52a
secondary = #e60053
alert = #bd2c40

height = 20

font-0 = "DejaVuSans:pixelsize=10;1"
font-1 = "siji:size=10;1"
font-2 = "unifont:fontformat=truetype:size=8:antialias=true;0"
font-3 = "FontAwesome:pixelsize=08;0"

bar-indicator = |
bar-indicator-foreground = #fff

ramp-0 = ▁
ramp-1 = ▂
ramp-2 = ▃
ramp-3 = ▄
ramp-4 = ▅
ramp-5 = ▆
ramp-6 = ▇
ramp-7 = █
ramp-foreground-0 = #55aa55
ramp-foreground-1 = #55aa55
ramp-foreground-2 = #55aa55
ramp-foreground-3 = #f5a70a
ramp-foreground-4 = #f5a70a
ramp-foreground-5 = #f5a70a
ramp-foreground-6 = #ff5555
ramp-foreground-7 = #ff5555

ramp-battery-0 = 
ramp-battery-1 = 
ramp-battery-2 = 
ramp-battery-3 = 
ramp-battery-4 = 

wireless-interface = WIRELESS_INTERFACE

[bar/bottom]
;monitor = ${env:MONITOR:HDMI-1}
width = 100%
bottom = true
height = ${theme.height}
;offset-x = 1%
;offset-y = 1%
radius = 0
fixed-center = false

background = ${theme.background}
foreground = ${theme.foreground}

line-size = 2
line-color = #f00

border-size = 0
border-color = #00000000

padding-left = 2
padding-right = 2

module-margin-left = 2
module-margin-right = 2

font-0 = ${theme.font-0}
font-1 = ${theme.font-1}
font-2 = ${theme.font-2}
font-3 = ${theme.font-3}

modules-left = backlight-acpi battery pulseaudio xkeyboard cpu temperature memory filesystem wlan download upload exchange-rates weather
modules-center = date prayertimes
; TODO calendar

tray-position = right
tray-padding = 2
;tray-background = #0063ff

;override-redirect = true
cursor-click = pointer
cursor-scroll = ns-resize

[bar/top]
;monitor = ${env:MONITOR:HDMI-1}
width = 100%
height = ${theme.height}
offset-x = 1%
offset-y = 1%
radius = 0
fixed-center = false

background = ${theme.background}
foreground = ${theme.foreground}

line-size = 3
line-color = #f00

border-size = 0
border-color = #00000000

padding-left = 0
padding-right = 1

module-margin-left = 1
module-margin-right = 2

font-0 = ${theme.font-0}
font-1 = ${theme.font-1}
font-2 = ${theme.font-2}
font-3 = ${theme.font-3}

modules-left = i3  
modules-center = xwindow
modules-right = music qbittorrents dropbox podcasts rss taskwarrior

wm-restack = i3

;override-redirect = true

scroll-up = i3wm-wsprev
scroll-down = i3wm-wsnext

cursor-click = pointer
cursor-scroll = ns-resize

[module/xwindow]
type = internal/xwindow
format = <label>
label = %title%
label-maxlen = 120
label-empty = {{ .chezmoi.username }}
label-empty-foreground = #707880

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format = %{A1:~/scripts/xkbdlayout -s:}<label-layout> <label-indicator>%{A-}
format-spacing = 0
format-prefix = " "
format-prefix-foreground = ${theme.foreground-alt}
format-prefix-underline = #bbb

label-layout = %layout%
label-layout-padding = 2
label-layout-underline = #bbb

layout-icon-default = 
indicator-icon-default = 

label-indicator-on = +%name%
label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = #bbb
label-indicator-underline = #bbb

[module/filesystem]
type = internal/fs
interval = 25
mount-0 = /
fixed-values = true
format-mounted = %{A1:~/scripts/polybar notify filesystem:}[ <label-mounted> ]%{A-}
format-mounted-prefix = " "
format-mounted-prefix-foreground = ${theme.foreground-alt}
format-mounted-underline = #DDD
label-mounted = %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${theme.foreground-alt}

[module/bspwm]
type = internal/bspwm

label-focused = %index%
label-focused-background = ${theme.background-alt}
label-focused-underline= ${theme.primary}
label-focused-padding = 2

label-occupied = %index%
label-occupied-padding = 2

label-urgent = %index%!
label-urgent-background = ${theme.alert}
label-urgent-padding = 2

label-empty = %index%
label-empty-foreground = ${theme.foreground-alt}
label-empty-padding = 2

; Separator in between workspaces
; label-separator = |

[module/i3]
type = internal/i3

pin-workspaces = false
index-sort = true
strip-wsnumbers = true
enable-click = true
enable-scroll = true
wrapping-scroll = false
fuzzy-match = false

ws-icon-0 = "1: ;"
ws-icon-1 = "2: ;"
ws-icon-2 = "3: ;"
ws-icon-3 = "4: ;"
ws-icon-4 = "5: ;"
ws-icon-5 = "6: ;"
ws-icon-6 = "7: ;"
ws-icon-7 = "8: ;"
ws-icon-8 = "9: ;"
ws-icon-9 = "10: ;"
ws-icon-default = ♟

format = <label-state> <label-mode>

label-mode = %mode%
label-mode-padding = 2
label-mode-foreground = #000
label-mode-background = ${theme.primary}

label-focused = %icon%
label-focused-background = ${theme.background-alt}
label-focused-underline= ${theme.primary}
label-focused-padding = 2

label-unfocused = %icon%
label-unfocused-padding = 2

label-visible = %icon%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}

label-urgent = %icon%
label-urgent-background = ${theme.alert}
label-urgent-padding = 2

; label-separator = |


[module/mpd]
type = internal/mpd
format-online = <label-song>  <icon-prev> <icon-stop> <toggle> <icon-next>

icon-prev = 
icon-stop = 
icon-play = 
icon-pause = 
icon-next = 

label-song-maxlen = 25
label-song-ellipsis = true

[module/music]
type = custom/script
exec = ~/scripts/music polybar
format = <label>
format-background = ${theme.background}
label = %output%
label-maxlen = 100
interval = 1

[module/qbittorrents]
type = custom/script
exec = ~/scripts/i3blocks/qbittorrents -f polybar
format = <label>
click-left = ~/scripts/i3blocks/qbittorrents -c alt-speed-limits
format-background = ${theme.background}
label = %output%
label-maxlen = 100
interval = 1

[module/xbacklight]
type = internal/xbacklight

format = <label> <bar>
label = BL

bar-width = 10
bar-indicator = ${theme.bar-indicator}
bar-indicator-foreground = ${theme.bar-indicator-foreground}
bar-indicator-font = 2
bar-fill = ─
bar-fill-font = 2
bar-fill-foreground = #9f78e1
bar-empty = ─
bar-empty-font = 2
bar-empty-foreground = ${theme.foreground-alt}

[module/backlight-acpi]
inherit = module/xbacklight
type = internal/backlight
card = intel_backlight

format = <ramp>

ramp-0 = 🌕
ramp-1 = 🌔
ramp-2 = 🌓
ramp-3 = 🌒
ramp-4 = 🌑

ramp-0-foreground = ${theme.ramp-foreground-0}
ramp-1-foreground = ${theme.ramp-foreground-2}
ramp-2-foreground = ${theme.ramp-foreground-4}
ramp-3-foreground = ${theme.ramp-foreground-6}
ramp-4-foreground = ${theme.ramp-foreground-7}

[module/cpu]
type = internal/cpu
interval = 2
format = %{A1:~/scripts/polybar notify cpu:}<label> <ramp-load>%{A}
format-prefix = " "
format-prefix-foreground = ${theme.foreground-alt}
format-underline = #f90000
label = %percentage%%

ramp-load-spacing = 1
ramp-load-0 = ${theme.ramp-0}
ramp-load-1 = ${theme.ramp-1}
ramp-load-2 = ${theme.ramp-2}
ramp-load-3 = ${theme.ramp-3}
ramp-load-4 = ${theme.ramp-4}
ramp-load-5 = ${theme.ramp-5}
ramp-load-6 = ${theme.ramp-6}
ramp-load-7 = ${theme.ramp-7}


ramp-load-0-foreground = ${theme.ramp-foreground-0}
ramp-load-1-foreground = ${theme.ramp-foreground-1}
ramp-load-2-foreground = ${theme.ramp-foreground-2}
ramp-load-3-foreground = ${theme.ramp-foreground-3}
ramp-load-4-foreground = ${theme.ramp-foreground-4}
ramp-load-5-foreground = ${theme.ramp-foreground-5}
ramp-load-6-foreground = ${theme.ramp-foreground-6}
ramp-load-7-foreground = ${theme.ramp-foreground-7}

[module/memory]
type = internal/memory
interval = 2
format = %{A1:~/scripts/polybar notify memory:}<label> <ramp-used>%{A}
format-prefix = " "
format-prefix-foreground = ${theme.foreground-alt}
format-underline = #4bffdc
label = %percentage_used%%

bar-used-indicator =
bar-used-width = 50
bar-used-foreground-0 = #55aa55
bar-used-foreground-1 = #557755
bar-used-foreground-2 = #f5a70a
bar-used-foreground-3 = #ff5555
bar-used-fill = ▐
bar-used-empty = ▐
bar-used-empty-foreground = #444444

ramp-used-0 = ${theme.ramp-0}
ramp-used-1 = ${theme.ramp-1}
ramp-used-2 = ${theme.ramp-2}
ramp-used-3 = ${theme.ramp-3}
ramp-used-4 = ${theme.ramp-4}
ramp-used-5 = ${theme.ramp-5}
ramp-used-6 = ${theme.ramp-6}
ramp-used-7 = ${theme.ramp-7}

ramp-free-0 = ${theme.ramp-0}
ramp-free-1 = ${theme.ramp-1}
ramp-free-2 = ${theme.ramp-2}
ramp-free-3 = ${theme.ramp-3}
ramp-free-4 = ${theme.ramp-4}
ramp-free-5 = ${theme.ramp-5}
ramp-free-6 = ${theme.ramp-6}
ramp-free-7 = ${theme.ramp-7}

ramp-used-0-foreground = ${theme.ramp-foreground-0}
ramp-used-1-foreground = ${theme.ramp-foreground-1}
ramp-used-2-foreground = ${theme.ramp-foreground-2}
ramp-used-3-foreground = ${theme.ramp-foreground-3}
ramp-used-4-foreground = ${theme.ramp-foreground-4}
ramp-used-5-foreground = ${theme.ramp-foreground-5}
ramp-used-6-foreground = ${theme.ramp-foreground-6}
ramp-used-7-foreground = ${theme.ramp-foreground-7}

[module/wlan]
type = internal/network
interface = ${theme.wireless-interface}
interval = 3.0

format-connected = %{A1:~/scripts/polybar notify wifi:}<ramp-signal> <label-connected> <ramp-signal>%{A}
format-connected-underline = #9f78e1
label-connected =  %signal%%
label-connected-foreground = #eefafafa

format-disconnected = <label-disconnected>
format-disconnected-underline = ${self.format-connected-underline}
label-disconnected =  %ifname% 
label-disconnected-foreground = ${theme.foreground}

format-packetloss = <animation-packetloss> <label-connected>

ramp-signal-foreground = ${theme.foreground-alt}
ramp-signal-0 = 
ramp-signal-1 = 
ramp-signal-2 = 
ramp-signal-3 = 
ramp-signal-4 = 
ramp-signal-5 = 

ramp-signal-0-foreground = ${theme.ramp-foreground-7}
ramp-signal-1-foreground = ${theme.ramp-foreground-6}
ramp-signal-2-foreground = ${theme.ramp-foreground-4}
ramp-signal-3-foreground = ${theme.ramp-foreground-3}
ramp-signal-4-foreground = ${theme.ramp-foreground-1}
ramp-signal-5-foreground = ${theme.ramp-foreground-0}

animation-packetloss-0 = ⚠
animation-packetloss-0-foreground = #ffa64c
animation-packetloss-1 = 📶
animation-packetloss-1-foreground = #000000
animation-packetloss-framerate = 500



[module/download]
type = internal/network
interface = ${theme.wireless-interface}
interval = 3.0
accumulate-stats = true
format-connected-prefix = 
format-connected-prefix-foreground = #32dd1f
format-connected = <label-connected>
format-connected-underline = #32dd1f
label-connected = %downspeed:9%
label-connected-foreground = #32dd1f
format-disconnected =
format-disconnected-underline = ${self.format-connected-underline}
format-packetloss =

[module/upload]
type = internal/network
interface = ${theme.wireless-interface}
interval = 3.0
accumulate-stats = true
format-connected-suffix = " "
format-connected-suffix-foreground = #dd1f1f
format-connected = <label-connected>
format-connected-underline = #dd1f1f
label-connected = %upspeed:9%
label-connected-foreground = #dd1f1f
format-disconnected =
format-disconnected-underline = ${self.format-connected-underline}
format-packetloss =

[module/eth]
type = internal/network
interface = enp9s0
interval = 3.0

format-connected-underline = #55aa55
format-connected-prefix = " "
format-connected-prefix-foreground = ${theme.foreground-alt}
label-connected = %local_ip%

format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${theme.foreground-alt}

[module/date]
type = internal/date
interval = 5

date =
; date-alt =  [ %Y-%m-%d - 
date-alt = [ %Y-%m-%d - 

; time =  [ %H:%M ]
time = [ %H:%M ]
time-alt = %H:%M:%S ]

format-prefix = 
format-prefix-foreground = ${theme.foreground-alt}
format-underline = #0a6cf5

label = %date% %time%

[module/prayertimes]
type = custom/script
exec = ~/scripts/prayertimes polybar
format = <label>
; format-prefix = 
format-prefix-font = 3
format-underline = #0a6cf5
label = %output%
interval = 1
click-left = ~/scripts/prayertimes notify

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <ramp-volume> <label-volume>
format-muted = <label-muted>
format-volume-underline = ${root.foreground}
label-volume = %percentage%%
label-volume-foreground = ${root.foreground}
label-volume-underline = ${root.foreground}

label-muted = 
label-muted-foreground = #666
label-muted-underline = #666

ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 

ramp-volume-0-foreground = ${theme.ramp-foreground-0}
ramp-volume-1-foreground = ${theme.ramp-foreground-3}
ramp-volume-2-foreground = ${theme.ramp-foreground-7}

click-right = pavucontrol &

bar-volume-width = 10
bar-volume-foreground-0 = ${theme.ramp-foreground-0}
bar-volume-foreground-1 = ${theme.ramp-foreground-1}
bar-volume-foreground-2 = ${theme.ramp-foreground-2}
bar-volume-foreground-3 = ${theme.ramp-foreground-3}
bar-volume-foreground-4 = ${theme.ramp-foreground-4}
bar-volume-foreground-5 = ${theme.ramp-foreground-5}
bar-volume-foreground-6 = ${theme.ramp-foreground-6}
bar-volume-gradient = true
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ─
bar-volume-fill-font = 2
bar-volume-empty = ─
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${theme.foreground-alt}

[module/alsa]
type = internal/alsa

format-volume = <label-volume> <bar-volume>
label-volume = VOL
label-volume-foreground = ${root.foreground}

format-muted-prefix = " "
format-muted-foreground = ${theme.foreground-alt}
label-muted = sound muted

bar-volume-width = 10
bar-volume-foreground-0 = ${theme.ramp-foreground-0}
bar-volume-foreground-1 = ${theme.ramp-foreground-1}
bar-volume-foreground-2 = ${theme.ramp-foreground-2}
bar-volume-foreground-3 = ${theme.ramp-foreground-3}
bar-volume-foreground-4 = ${theme.ramp-foreground-4}
bar-volume-foreground-5 = ${theme.ramp-foreground-5}
bar-volume-foreground-6 = ${theme.ramp-foreground-6}
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ─
bar-volume-fill-font = 2
bar-volume-empty = ─
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${theme.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT1
adapter = ACAD
full-at = 98

format-charging = <animation-charging> <label-charging>
format-charging-underline = #ffb52a

format-discharging = <ramp-capacity> <label-discharging>
format-discharging-underline = ${self.format-charging-underline}

format-full-prefix = " "
format-full-prefix-foreground = ${theme.ramp-foreground-4}
format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = ${theme.ramp-battery-0}
ramp-capacity-1 = ${theme.ramp-battery-1}
ramp-capacity-2 = ${theme.ramp-battery-2}
ramp-capacity-3 = ${theme.ramp-battery-3}
ramp-capacity-4 = ${theme.ramp-battery-4}
ramp-capacity-0-foreground = ${theme.ramp-foreground-7}
ramp-capacity-1-foreground = ${theme.ramp-foreground-6}
ramp-capacity-2-foreground = ${theme.ramp-foreground-4}
ramp-capacity-3-foreground = ${theme.ramp-foreground-2}
ramp-capacity-4-foreground = ${theme.ramp-foreground-1}

animation-charging-0 = ${theme.ramp-battery-0}
animation-charging-1 = ${theme.ramp-battery-1}
animation-charging-2 = ${theme.ramp-battery-2}
animation-charging-3 = ${theme.ramp-battery-3}
animation-charging-4 = ${theme.ramp-battery-4}
animation-charging-foreground = ${theme.ramp-foreground-4}
animation-charging-framerate = 500

animation-discharging-0 = ${theme.ramp-battery-4}
animation-discharging-1 = ${theme.ramp-battery-3}
animation-discharging-2 = ${theme.ramp-battery-2}
animation-discharging-3 = ${theme.ramp-battery-1}
animation-discharging-4 = ${theme.ramp-battery-0}
animation-discharging-framerate = 500
animation-discharging-foreground = ${theme.foreground-alt}

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format = <ramp> <label>
format-underline = #f50a4d
format-warn = <ramp> <label-warn>
format-warn-underline = ${self.format-underline}

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${theme.secondary}

ramp-0 = 
ramp-1 = 
ramp-2 = 
ramp-foreground = ${theme.foreground-alt}

[module/exchange-rates]
type = custom/script
exec = ~/scripts/exchange USDTRY
format = <label>
; format-overline = #85bb65
format-underline = #85bb65
label = %output%
label-maxlen = 30
click-left = notify-send "Exchange Rates" "   $(cat ~/scripts/.exchange_rates | jq '.TRY')\n   TODO\n  ل.س TODO"
interval = 60

[module/weather]
type = custom/script
exec = ~/scripts/weather polybar
format = <label>
; format-underline = #F9EE54
label = %output%
label-maxlen = 30
click-left = ~/scripts/weather notify
interval = 60

[module/rss]
type = custom/script
exec = ~/scripts/rss polybar
format = <label>
; format-underline = #f26522
label = %output%
label-maxlen = 30
click-left = ~/scripts/rss notify
interval = 60

[module/podcasts]
type = custom/script
exec = ~/scripts/podcasts polybar
format = <label>
; format-underline = #a26eea
label = %output%
label-maxlen = 30
click-left = ~/scripts/podcasts notify
interval = 60

[module/torn]
type = custom/script
exec = ~/scripts/torn polybar
format = <label>
label = %output%
label-maxlen = 100
click-left = ~/scripts/torn notiy
interval = 1
; TODO add notifications

[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 1

label-open = 
label-open-foreground = ${theme.secondary}
label-close =  cancel
label-close-foreground = ${theme.secondary}
label-separator = |
label-separator-foreground = ${theme.foreground-alt}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = sudo reboot

menu-2-0 = power off
menu-2-0-exec = sudo poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[settings]
screenchange-reload = true
; compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[global/wm]
margin-top = 0
margin-bottom = 0

; vim:ft=dosini
