## Format
datetime-format "%F"
feedlist-format "%?T?║%4i %n (%-4U) (%T) %t &╠ %-15t═════════════════════════════════════════════════════?"
notify-format "newsbeuter: %n unread articles within %f unread feeds"
articlelist-format "%4i %f %D %6L  %?T?|%-17T|  ?%t"
articlelist-title-format " %N-v%V - %u/%t - %T"
feedlist-title-format " %N-v%V - %t Feeds with %u unread articles%?T? - %T?"
searchresult-title-format " %N-v%V - Search result %u/%t"
help-title-format " %N-v%V - Help"
filebrowser-title-format " %N-v%V - %?O?Open file:&Save file? - %f"
selecttag-title-format " %N-v%V - Select a tag"
selectfilter-title-format " %N-v%V - Select a filter"
itemview-title-format " %N-v%V - %T"
urlview-title-format " %N-v%V - Urls found in this article"
# dialogs-title-format " %N-v%V - Select a dialog")"

## Colors
color background            default   default  invis
color info                  default   default  reverse
color listnormal            default   default
color listfocus             default   default  reverse
color article               default   default
color listnormal_unread     default   default  bold
color listfocus_unread      default   default  reverse bold
search-highlight-colors     color223  default  bold underline

## Highlight
highlight feedlist "[║│]"                             blue default bold
highlight feedlist "╠═.*"                             blue default bold
highlight feedlist ".*\\(query\\) .*"                 yellow
highlight feedlist ".*\\(news\\) .*"                  white
highlight feedlist ".*\\(books\\) .*"                 black yellow bold
highlight feedlist ".*\\(culture\\) .*"               blue
highlight feedlist ".*\\((business|economics)\\) .*"  red
highlight feedlist ".*\\(comics\\) .*"                green
highlight feedlist ".*\\(podcast\\) .*"               magenta
highlight feedlist ".*\\(reddit\\) .*"                yellow
# too many unread articles ( >= 50 )
# highlight feedlist  "\\(([0-9]{3,}|[5-9][0-9])/" color154 default blink
# good guy
#highlight-article   "author =~ \"陈皓\" color154 default
# my favorite subjects
#highlight-article   "title =~ \"(都市|玄幻)\" color154 default


highlight feedlist    "^  *[0-9]+  *N  "                    color156 default    underline
highlight articlelist "^  *[0-9]+  *N  "                    color156 default

highlight article     "^Title:.*"                           yellow   default bold
highlight article     "^Feed:.*"                            magenta  default
highlight article     "^Author:.*"                          green    default
highlight article     "^Date:.*"                            color223 default
highlight article     "^Link:.*"                            blue     default
highlight article     "^Flags:.*"                           color9   default
highlight article     "^Podcast Download URL:.*"            color71  default
highlight article     "^Links:"                             white    color240 underline
# highlight article     "\\[[0-9][0-9]*\\]"                   color72  default  bold
# highlight article     "\\[image [0-9][0-9]*\\]"             color72  default  bold
# highlight article     "\\[embedded flash: [0-9][0-9]*\\]"   color72  default  bold
highlight article     "\\[[0-9][0-9]*\\]"                   color66  default bold
highlight article     "\\[image [0-9][0-9]*\\]"             color109 default bold
highlight article     "\\[embedded flash: [0-9][0-9]*\\]"   color66  default bold
highlight article     ":.*\\(link\\)$"                      color74  default
highlight article     ":.*\\(image\\)$"                     color74  default
highlight article     ":.*\\(embedded flash\\)$"            color74  default
