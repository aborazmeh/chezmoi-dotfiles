# ----------------------------------------------------------------------
# file:    ~/.config/newsboat/config
# author:  {{ .chezmoi.username}}
# date:    07/09/2025 - 21:08 UTC
# vim: set ai et fenc=utf-8 ft=conf nu si sts=0 sw=4 ts=8 tw=0 :
# ----------------------------------------------------------------------

## General
cache-file "~/.newsbeuter/cache.db"
cleanup-on-quit yes
cookie-cache ""
error-log "~/.newsbeuter/error.log"
#include
opml-url ""
show-keymap-hint yes
urls-source local
swap-title-and-hints false

## Viewing
wrap-scroll yes
always-display-description false
confirm-mark-feed-read yes
confirm-exit no
display-article-progress yes
# external-url-viewer "urlscan"
external-url-viewer "/usr/bin/urlview"
feed-sort-order none
article-sort-order date-asc
goto-first-unread yes
goto-next-feed yes
history-limit 100
html-renderer internal
#html-renderer "/usr/bin/elinks -dump"
# html-renderer "w3m"
pager internal
# pager "w3m -T text/html"
show-read-feeds yes
show-read-articles yes
#text-width 72
text-width 0
# hide articles matching
ignore-article "*" "title =~ \"Sponsor\""
ignore-article "*" "title =~ \"Advertisement\""
ignore-mode "display"
# kill files ignore articles marked #shorts to filter out youtube shorts
ignore-article "*" "title =~ \"#shorts$\""

## Browser
browser "swaymsg workspace 3; qutebrowser >/dev/null 2>&1 %u &"  # xdg-open midori epiphany qutebrowser falkon luakit eolie nyxt vimb
# macro y set browser "mpv %u"; open-in-browser ; set browser "swaymsg workspace 3; qutebrowser >/dev/null 2>&1 %u &"
# macro o set browser "vimprobable2 %u"; open-in-browser ; set browser "swaymsg workspace 3; qutebrowser >/dev/null 2>&1 %u &"
# macro w set browser "w3m %u"; open-in-browser ; set browser "swaymsg workspace 3; qutebrowser >/dev/null 2>&1 %u &"
# macro m set browser "mpv %u"; open-in-browser ; set browser "swaymsg workspace 3; qutebrowser >/dev/null 2>&1 %u &"
# macro . set browser "{{ .chezmoi.homeDir }}/scripts/sauron %u"; open-in-browser ; set browser "swaymsg workspace 3; qutebrowser >/dev/null 2>&1 %u &"
macro r set browser "python3 -m readability.readability -u %u 2>/dev/null | w3m -T text/html"; open-in-browser ; set browser "swaymsg workspace 3; qutebrowser >/dev/null 2>&1 %u &" # ; set browser "epiphany %u >/dev/null 2>&1 &"
# macro l set browser "xdg-open %u"; open-in-browser ; set browser "swaymsg workspace 3; qutebrowser >/dev/null 2>&1 %u &"
# macro p set browser "{{ .chezmoi.homeDir }}/scripts/punch -i %u 2> /dev/null"; one; set browser "swaymsg workspace 3; qutebrowser >/dev/null 2>&1 %u &"

## Updating
auto-reload yes
download-retries 4
download-full-page yes
download-timeout 30
http-auth-method any
mark-as-read-on-hover no
max-download-speed 0
notify-program notify-send
notify-xterm yes
notify-screen no
notify-beep no
notify-always no
refresh-on-startup no
reload-only-visible-feeds no
reload-time 30
reload-threads 100
#reset-unread-on-update
suppress-first-reload yes

## GoogleReader
#googlereader-flag-share ""
#googlereader-flag-star ""
#googlereader-login ""
#googlereader-password ""
#googlereader-passwordfile ""
#googlereader-min-items 20
#googlereader-show-special-feeds yes

## Filters
#define-filter

## Archivement
always-download ""
keep-articles-days 30
max-items 0
podcast-auto-enqueue no
prepopulate-query-feeds yes
use-proxy no
proxy 127.0.0.1:8118
#proxy-auth
proxy-auth-method any
proxy-type http
save-path "~/.newsbeuter/saved"
user-agent ""
#user-agent "Chrome/31.0.0.0"
## podbeuter
download-path "~/Music/podcasts/%h/%n"
max-downloads 3
player $PLAYER

## Marking
bookmark-cmd ""
bookmark-interactive yes
ttrss-flag-publish ""
ttrss-flag-star ""
ttrss-login ""
#ttrss-passowrd ""
ttrss-mode single
ttrss-url ""

