{
  "segments": {
    "right": [
      {
        "function": "powerline.segments.common.wthr.weather",
        "args": {
          "unit": "C",
          "location_query": "{{ .city }}, {{ .country }}"
        }
      },
      {
        "function": "powerline.segments.common.time.date",
        "name": "time",
        "args": {
          "format": " %Y/%m/%d - %H:%M",
          "istime": true
        }
      },
      {
        "function": "powerline.segments.common.bat.battery"
      }
    ]
  }
}
