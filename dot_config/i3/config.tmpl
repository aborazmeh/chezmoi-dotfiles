# Variables
set $mod Mod4
set $alt Mod1
set $terminal kitty tmux

# Options
focus_follows_mouse no
mouse_warping output
popup_during_fullscreen smart
force_focus_wrapping yes
focus_on_window_activation smart
workspace_auto_back_and_forth yes
default_border none
new_window 1pixel

# Font
#font pango:monospace 8
font pango:DejaVu Sans Mono 8, FontAwesome 8

# Key Bindings
# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# Start a terminal
bindsym $mod+Shift+Return exec $terminal

# Screen Lock
bindcode $mod+Ctrl+Shift+46 exec i3lock-fancy

# Change keyboard layout
bindcode 66 exec $HOME/scripts/xkbdlayout -s
bindsym $mod+Escape exec $HOME/scripts/xkbdlayout -s
bindsym $mod+Shift+Escape exec $HOME/scripts/xkbdlayout -w

# kill focused window
bindcode $mod+Shift+54 kill

# Minimization
set $minimize move scratchpad
set $unminimize scratchpad show
bindcode $mod+58 $minimize
bindcode $mod+Shift+58 $unminimize

# Program launcher
set $rofi_cmd "rofi -show-icons -combi-modi window,drun,ssh -show combi -lines 9 -bw 0 -bg #FFFFFF"
# bindsym $alt+space exec $rofi_cmd
bindcode $mod+27 exec $rofi_cmd
bindcode $mod+33 exec dmenu_run
#bindcode $mod+40 exec --no-startup-id i3-dmenu-desktop
bindcode $mod+Shift+33 exec gmrun

# Calculator
bindcode $mod+21 exec "$HOME/.rofi/calc.sh"
bindcode $mod+54 exec "$HOME/.rofi/calc.sh"

# Screenshot
bindsym --release Print exec $HOME/scripts/screenshot fullscreen
bindsym --release Ctrl+Print exec $HOME/scripts/screenshot window
bindsym $mod+Print exec $HOME/scripts/screenshot teiler

# Searching the Web
bindcode $mod+Shift+61 exec rofi-surfraw

# Password Manager
bindcode $mod+Ctrl+33 exec rofi-pass

# TODO Browsing the filesystem
# bindcode $mod+26

# change focus
bindcode $mod+43 focus left
bindcode $mod+44 focus down
bindcode $mod+45 focus up
bindcode $mod+46 focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindcode $mod+Shift+43 move left
bindcode $mod+Shift+44 move down
bindcode $mod+Shift+45 move up
bindcode $mod+Shift+46 move right
# move to another output
bindcode $mod+Ctrl+46 move container to output right
bindcode $mod+Ctrl+43 move container to output left
bindsym $mod+Ctrl+Right move workspace to output right
bindsym $mod+Ctrl+Left move workspace to output left

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindcode $mod+118 split 43

# split in vertical orientation
bindcode $mod+shift+55 split v

# enter fullscreen mode for the focused container
bindcode $mod+41 fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
workspace_layout tabbed
# bindcode $mod+39 layout stacking
bindcode $mod+25 layout tabbed
bindcode $mod+26 layout toggle split

# toggle tiling / floating
bindcode $mod+28 floating toggle
bindcode $mod+39 sticky toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindcode $mod+38 focus parent

# focus the child container
#bindcode $mod+40 focus child

# Function Keys

#bindsym XF86Power exec "sh ~/.config/awesome/scripts/shutdown.sh"
bindsym XF86MonBrightnessDown exec "light -U 15"
bindsym XF86MonBrightnessUp exec "light -A 15"
bindsym $mod+F4 exec "$HOME/.rofi/monitor_layout.sh"
bindsym $mod+Shift+F4 exec "$HOME/.rofi/rofi-randr"
bindsym XF86AudioPlay exec "$HOME/scripts/music -c toggle"
bindsym $mod+XF86AudioPlay exec "clerk"
# XF86AudioPlay with Ctrl to stop
bindsym Ctrl+XF86AudioPlay exec "$HOME/scripts/music -c stop"
# XF86AudioPrev to seek
bindsym XF86AudioPrev exec "$HOME/scripts/music -c seek-"
# XF86AudioPrev with Ctrl to previous track
bindsym Ctrl+XF86AudioPrev exec "$HOME/scripts/music -c prev"
# XF86AudioNext to seek
bindsym XF86AudioNext exec "$HOME/scripts/music -c seek+"
# XF86AudioNext with Ctrl to next track
bindsym Ctrl+XF86AudioNext exec "$HOME/scripts/music -c next"
bindsym XF86AudioLowerVolume exec "$HOME/scripts/music -c volume-"
bindsym XF86AudioRaiseVolume exec "$HOME/scripts/music -c volume+"
bindsym XF86AudioMute exec "$HOME/scripts/music -c mute"

# Monitors
set $monitor_primary "eDP-1"
set $monitor_hdmi "HDMI1"

# Workspaces
set $ws_terminal "1: "
set $ws_dev "2: "
set $ws_web "3: "
