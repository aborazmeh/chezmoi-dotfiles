# switch to workspace
# Workspace Switcher
bindcode $mod+49 exec "$HOME/.rofi/i3_switch_workspace.sh"
# bindcode keys from 1-0 to switch to specific workspace
bindcode $mod+10 workspace $ws_terminal
bindcode $mod+11 workspace $ws_dev
bindcode $mod+12 workspace $ws_web
bindcode $mod+13 workspace $ws_office
bindcode $mod+14 workspace $ws_doc
bindcode $mod+15 workspace $ws_files
bindcode $mod+16 workspace $ws_vnc
bindcode $mod+17 workspace $ws_vm
bindcode $mod+18 workspace $ws_im
bindcode $mod+19 workspace $ws_media

# move focused container to workspace
bindcode $mod+Shift+49 exec "$HOME/.rofi/move_window_to_current"
bindcode $mod+Shift+10 move container to workspace $ws_terminal
bindcode $mod+Shift+11 move container to workspace $ws_dev
bindcode $mod+Shift+12 move container to workspace $ws_web
bindcode $mod+Shift+13 move container to workspace $ws_office
bindcode $mod+Shift+14 move container to workspace $ws_doc
bindcode $mod+Shift+15 move container to workspace $ws_files
bindcode $mod+Shift+16 move container to workspace $ws_vnc
bindcode $mod+Shift+17 move container to workspace $ws_vm
bindcode $mod+Shift+18 move container to workspace $ws_im
bindcode $mod+Shift+19 move container to workspace $ws_media

# Workspace Monitors
workspace $ws_terminal output $monitor_primary
workspace $ws_dev output $monitor_primary
workspace $ws_web output $monitor_primary
workspace $ws_office output $monitor_primary
workspace $ws_doc output $monitor_primary
