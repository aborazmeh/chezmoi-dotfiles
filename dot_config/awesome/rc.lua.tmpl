-- Mouse hover action
local battery= {}
local battery_notification = nil
battery_notification_preset = { fg = beautiful.fg_normal }

function battery:hide()
  if battery_notification ~= nil then
    naughty.destroy(battery_notification)
    battery_notification = nil
  end
end

function battery:show(t_out)
  battery:hide()

  asyncshell.request("acpi --battery",
  function(output)
    ws = output:read("*a")
  end)


  if bat_now.status == "Not present" then
    return
  elseif bat_now.status == "Charging" and ws:match("%d%d:%d%d:%d%d") then
    ws = "Charging | Remainaing: " .. ws:match("%d%d:%d%d:%d%d")
    battery_notification_preset = { fg = green }
    --batcharging:set_markup(markup("#FFFF00", " <b>⚡</b>"))
  elseif bat_now.status == "Discharging" and ws:match("%d%d:%d%d:%d%d") then 
    battery_notification_preset = { fg = red }
    ws = "Discharging | Remainaing: " .. ws:match("%d%d:%d%d:%d%d")
  else
    battery_notification_preset = { fg = green }
    ws = "Fully Charged."
  end

  battery_notification = naughty.notify({
    preset = battery_notification_preset,
    text = ws,
    timeout = t_out,
    position = "bottom_right"
  })
end

function battery:show_clicked(t_out)
  battery:hide()

  battery_notification_preset = {fg = beautiful.fg_normal}

  asyncshell.request("acpi --everything",
  function(output)
    ws = output:read("*a"):gsub("Thermal.+", "")
    battery_notification = naughty.notify({
      preset = battery_notification_preset,
      text = ws,
      timeout = t_out,
      position = "bottom_right"
  })
