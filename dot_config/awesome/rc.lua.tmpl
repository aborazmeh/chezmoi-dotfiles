function mpd:next_release()
      mpd_next_timer = timer ({timeout=2})
      mpd_next_timer:connect_signal("timeout", function() mpd_next_timer:stop() end)
      mpd_next_timer:start()

      volumewidget.update()
end

audio_card="PCH"
function mpd:swap_device()
  PCH=[[pcm.!default {
    type hw
    card 1
  }

  ctl.!default {
    type hw
    card 1
  }]]

  HDMI=[[pcm.!default {
    type hw
    card 0
  }

  ctl.!default {
    type hw
    card 0
  }]]

  local file, err = io.open(os.getenv("HOME") .. "/.asoundrc", "w")
  if file==nil then
    say("Couldn't open file: "..err)
  else
    if audio_card == "PCH" then
      audio_card = "HDMI"
      file:write(HDMI)
      file:close()
    elseif audio_card == "HDMI" then
      audio_card = "PCH"
      file:write(PCH)
      file:close()
    end
  end
end

