  asyncshell.request("python ~/.config/scripts/lyrics.py -a \"" .. mpd_now.artist .. "\"",
  function(output)
    ws = output:read("*a")
    mpd:hide()
    if (ws ~= "") then
      mpd:show(20,ws, "/tmp/mylyrics/" .. mpd_now.artist:gsub(" ", "+"):lower() .. ".jpg")
    end
  end)
end


