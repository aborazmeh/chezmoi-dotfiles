local dollar = {}
dollarwidget_text = wibox.widget.textbox()
dollarwidget = wibox.widget.background()
dollarwidget:set_widget(dollarwidget_text)
dollarwidget:set_bg("#313131")

dollarmenu_items = { }

currencies = { "USD_SYP", "USD_TRY", "EUR_TRY" }

dollar_cur = 0
function dollar:update()
  dollarwidget_text:set_text("?")

  dollar_cur = dollar_cur+1
  if dollar_cur > #currencies-1 then
    dollar_cur = 0
  end

  local file = io.open("/tmp/myexchange", "r")
  if file ~= nil then
    local exout = file:read("*a")
    file:close()
  else
    exout = ""
  end

  if dollar_cur == 0 then
    from = "USD"
    to = "SYP"
    buy = exout:match("USD_SYP_BUY: (.-)\n")
    sell = exout:match("USD_SYP_SELL: (.-)\n")
    state = exout:match("USD_SYP_STATE: (.-)\n")
  elseif dollar_cur == 1 then
    from = "USD"
    to = "TRY"
    if exout ~= nil then
      buy = exout:match("USD_TRY_BUY: (.-)\n")
      sell = exout:match("USD_TRY_SELL: (.-)\n")
      state = exout:match("USD_TRY_STATE: (.-)\n")
    end
  elseif dollar_cur == 2 then
    from = "EUR"
    to = "TRY"
    buy = exout:match("EUR_TRY_BUY: (.-)\n")
    sell = exout:match("EUR_TRY_SELL: (.-)\n")
    state = exout:match("EUR_TRY_STATE: (.-)\n")
  end

  -- Green for Up and Red for Down.
  if state == "▲" then
    state = markup("#00AC00", state)
  elseif state == "▼" then
    state = markup("#AC0000", state)
  end

  -- SYP, USD_TRY, EUR_TRY
  if to == "TRY" then
    dollarmenu = awful.menu({ items = { {"Big Para", function() open_url("http://www.bigpara.com/dolar/") end} } })
  elseif to == "SYP" then
    dollarmenu = awful.menu({ items = {
      {"Syria Stocks", function() open_url("http://syria-stocks.com/forum/") end},
      {"الليرة اليوم", function() open_url("http://www.sp-today.com/") end} 
    } })
end

  -- Don't do anything if there isn't valid values
  if not (buy and sell and state) then return end
  dollarwidget_text:set_markup(from .. "➤" .. to .. ": ".. markup(red, sell) .. " " .. state .. " " .. markup(cyan, buy))
end


