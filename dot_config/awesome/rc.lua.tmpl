{{ printf `-- {{{` }} Autostart apps
function apps_init()
  function run_once(prg,arg_string,pname,screen)
    if not prg then
      do return nil end
    end

    if not pname then
      pname = prg
    end

    if not arg_string then 
      awful.util.spawn_with_shell("pgrep -f -u $USER -x '" .. pname .. "' || (" .. prg .. ")",screen)
    else
      awful.util.spawn_with_shell("pgrep -f -u $USER -x '" .. pname .. " ".. arg_string .."' || (" .. prg .. " " .. arg_string .. ")",screen)
    end
  end

  local autostart_apps = {
    "xset b off",                       -- Turn off X Bell.
    "xrdb ~/.Xresources",
    "unagi",                            -- Compositing Manager, alternatives are: "cairo-compmgr &", "xcompmgr -cF &", "compton".
    --"konsole",
    --"mpd ~/.mpd.conf",
    --"znc",                              -- IRC Bouncer.
    "nm-applet",
    --"firefox",
    --"nautilus",
    --"dropbox",                          -- Dropbox.
    "megasync",
    "numlockx",
    "synclient TapButton1=1",
    --"qbittorrent",
    --"synapse",
    --"skype",
    --"pidgin",
    --"konsole -e ", IRSSI!
    --"wine $HOME/.wine/drive_c/Program\\ Files\\ (x86)/DVR/UMS\\ Client/UMS_Client"
  }

  for p=1, #autostart_apps do
    run_once(autostart_apps[p])
  end

end
-- }}}

