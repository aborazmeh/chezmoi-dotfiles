function mpd:mpdicon_pressed()
  mpd:hide()

  local cursong = mpd_now.artist .. " - " .. mpd_now.title

  after = asyncshell.demand("mpc -h " .. mpd_password .. "@" .. mpd_server .. " playlist | grep -A 10 \"" .. cursong .. "\"|replace \"" .. cursong .. "\" \"\"", 1):read("*a")
  before = asyncshell.demand("mpc -h " .. mpd_password .. "@" .. mpd_server .. " playlist | grep -B 10 \"" .. cursong .. "\"|replace \"" .. cursong .. "\" \"\"", 1):read("*a")

  ws = before .. mpdartist .. " - " ..  mpdtitle .. after
  ws = ws:gsub("\n\n","\n")

  mpd:hide()
  if (ws ~= "") then
    mpd:show(0,ws)
  end
end

function mpd:play_pause_press(args)
      if (args == "pause") then
        awful.util.spawn("mpc -h " .. mpd_password .. "@" .. mpd_server .. " toggle")
      elseif (args == "stop")then
        awful.util.spawn("mpc -h " .. mpd_password .. "@" .. mpd_server .. " stop")
      end

      volumewidget.update()
end

function mpd:prev_press(args)
      if  (args == "prev") then
        awful.util.spawn("mpc -h " .. mpd_password .. "@" .. mpd_server .. " prev")
      elseif (args == "seek") then
        awful.util.spawn("mpc -h " .. mpd_password .. "@" .. mpd_server .. " seek -10")
      end


      volumewidget.update()
end

function mpd:next_press(args)
      if  (args == "next") then
        awful.util.spawn("mpc -h " .. mpd_password .. "@" .. mpd_server .. " next")
      elseif (args == "seek") then
