function mpd:hide()
  if mpd_notification ~= nil then
    naughty.destroy(mpd_notification)
    mpd_notification = nil
  end
end

function mpd:show(t_out, mpdnottext, mpdnoticon)
  mpd:hide()
  if not mpd_now then return end
  if mpd_now.state ~= "play" then return end

  --nottext = (nottext ~= nil) ? nottext : (string.format("%s %s - %s\n%s", artist, album, date, title))
  if (not mpdnottext) then
    mpdnottext = string.format("%s %s - %s\n%s", mpdartist, mpdalbum, mpddate, mpdtitle)
  end

  if (not mpdnoticon) then
    mpdnoticon = "/tmp/mpdcover.png"
  end

  mpd_notification = naughty.notify({
    preset = mpd_notification_preset,
    icon = mpdnoticon,
    text = mpdnottext,
    timeout = t_out,
    position = "top_right"
  })
end

function mpd:mpdwidget_pressed()
  mpd:hide()

  --TODO: Edit this command to show the current song colored in the exact center
  ws = asyncshell.demand("mpc -h " .. mpd_password .. "@" .. mpd_server .. " --format '%time%\t%artist%, %title%' playlist|head -n 10", 1):read("*a"):gsub("\t,", "\t")

  mpd:show(0,ws)
end

function mpd:mpd_duration_widget_pressed()
  mpd:hide()

  asyncshell.request("mpc -h " .. mpd_password .. "@" .. mpd_server .. " --format '%time%' playlist | awk -F ':' 'BEGIN{t=0} {t+=$1*60+$2} END{print strftime(\"%H:%M:%S\")}'",
  function(output)
    ws = output:read("*a")
    ws = "Total Playlist Duration: " .. ws
    mpd:show(0,ws)
  end)
end

function mpd:mpdwidget_artist_pressed()
