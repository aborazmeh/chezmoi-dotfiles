for_window [app_id="org.keepassxc.KeePassXC" title="KeePassXC - Browser Access Request"] floating enable
for_window [app_id="espanso"] floating enable
for_window [app_id="nheko" title="Select file(s)"] floating enable

# Misc
# for_window [urgent="latest"] focus
# for_window [app_id="firefox" title="^Firefox — Sharing Indicator$"] kill
# for_window [app_id="firefoxdeveloperedition" title="^Firefox Developer Edition — Sharing Indicator$"] kill

# autotiling manager
exec_always autotiling

# Notify daemon
exec swaync

exec swayidle -w \
         timeout 300  'swaylock' \
         timeout 600  'swaymsg "output * dpms off"' \
              resume  'swaymsg "output * dpms on"' \
         before-sleep 'swaylock'

# Fire up apps
exec mkfifo $SWAYSOCK.wob && tail -f $SWAYSOCK.wob | wob
exec $HOME/scripts/bar/music --frontend sway --daemon
exec kanata
exec wlsunset -l $latitude -L $longitude
{{- if eq .machine "home" }}
exec megasync
# exec play_audiobook mpv
# exec mpd ~/.mpd.conf
# exec $HOME/scripts/play_audiobook mopidy
# exec $terminal
exec kdeconnect-indicator
# exec telegram-desktop
# exec whatsdesk
# exec discord
# Start dbus for gnome-keyring to run
# required packages gnome-keyring libsecret libgnome-keyring
exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK
# exec_always "systemctl --user import-environment"
# exec --no-startup-id libinput-gestures-setup start
# exec blueman-applet
# exec nm-applet --indicator
# exec emacs --daemon
# exec wluma
# exec udiskie --automount --tray --notify --appindicator
# exec wl-paste -t text --watch clipman store
{{- end }}

# Wallpaper
output "*" bg ~/Pictures/backgrounds/wallpaper.webp fill
{{- if eq .machine "home" }}
# exec_always $HOME/scripts/wallpapers -m bing -f sway

# reload configs on changes
# exec "$HOME/scripts/reload-configs"
{{- end }}

# System config
include /etc/sway/config.d/*
