# Variables
set $mod Mod4
set $alt Mod1

set $float-sticky-video floating enable, sticky enable, exec "$HOME/scripts/sway-move-to bottom-right"
set $terminal ghostty -e tmux new-session -A -D -s main
set $editor ghostty -e micro

set $scratchpad $editor {{ if eq .machine "home" -}} ~/MEGA/scratchpad.md {{- else -}} ~/scratchpad.md {{- end }}
set $filemanager ghostty -e ranger
set $browser firefox --new-tab about:blank
set $mailclient thunderbird
set $minimize move scratchpad
set $unminimize scratchpad show
# wofi --allow-images --allow-markup --gtk-dark --show drun,run f
set $rofi_cmd "rofi -show combi -combi-modes drun,window,ssh"
set $calculator "$HOME/.rofi/calc.sh"

# Monitors
set $monitor_primary "eDP-1"
set $monitor_hdmi "HDMI-A-1"

output $monitor_primary pos 0 0 res 1920x1080 scale 1
output $monitor_hdmi {
  # pos 1920 0
  # res 1920x1080
  # mode 1920x1080@60Hz
  # scale 1
  # transform 270
}

# Workspaces
set $ws_terminal "1"
set $ws_dev "2"
set $ws_web "3"
set $ws_office "4"
set $ws_doc "5"
set $ws_files "6"
set $ws_vnc "7"
set $ws_vm "8"
set $ws_im "9"
set $ws_media "10"

# Workspace Monitors
workspace $ws_terminal output $monitor_primary
workspace $ws_dev output $monitor_primary
workspace $ws_web output $monitor_hdmi
workspace $ws_office output $monitor_primary
workspace $ws_doc output $monitor_primary
workspace $ws_files output $monitor_primary
workspace $ws_im output $monitor_primary
workspace $ws_media output $monitor_hdmi

# Options
focus_follows_mouse no
mouse_warping output
popup_during_fullscreen smart
# force_focus_wrapping yes  use focus_wrapping
focus_on_window_activation smart
workspace_auto_back_and_forth yes
xwayland enabled
workspace_layout tabbed

# Theme
gaps outer 0
gaps inner 2
default_border pixel 2
hide_edge_borders --i3 smart
smart_borders on
smart_gaps on
show_marks yes
#font pango:monospace 8
font pango:DejaVu Sans Mono 8, FontAwesome 8
include "$HOME/.cache/wal/colors-sway"
# client.<class> <border> <background> <text> [<indicator> [<child_border>]]
client.background $background $background $background
client.focused $color0 $background $foreground $color7 $background
# |focused_inactive  | #333333 | #5f676a    | #ffffff | #484e50   | #5f676a      |
# |focused_tab_title | #333333 | #5f676a    | #ffffff | n/a       | n/a          |
# |unfocused         | #333333 | #222222    | #888888 | #292d2e   | #222222      |
# |urgent            | #2f343a | #900000    | #ffffff | #900000   | #900000      |
# |placeholder       | #000000 | #0c0c0c    | #ffffff | #000000   | #0c0c0c

# Bar
# bar {
  # position bottom
  # swaybar_command waybar
  # pango_markup enabled
  # mode hide
  # hidden_state hide
# }
exec waybar

# Seat
seat * {
  hide_cursor 3000
}

# Input
input "type:keyboard" {
  # xkb_file ~/keymap.xkb
  xkb_layout us,ara
  xkb_model pc101
  # xkb_variant workman,
  xkb_options grp:caps_toggle
  #,grp:alt_shift_toggle
  # xkb_rules
  xkb_numlock enabled
  repeat_delay 500
  repeat_rate 50
}

input "type:touchpad" {
  tap enabled
  drag enabled
  # drag_lock enabled
  click_method button_areas
  dwt enabled
  middle_emulation enabled
  natural_scroll enabled
  accel_profile adaptive
  events enabled
  scroll_method two_finger
}

input "2:7:SynPS/2_Synaptics_TouchPad" {
}

# Switches
bindswitch --reload --locked {
  # Laptop lid switch
  lid:on output $monitor_primary disable
  lid:off output $monitor_primary enable
}

# Key Bindings
# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

bindsym --to-code {
  # reload the configuration file
  $mod+q reload
  $mod+Shift+q exec "swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your session.' -b 'Yes, exit sway' 'swaymsg exit'"

  # Start a terminal
  $mod+Shift+Return exec $terminal

  # Screen Lock
  $mod+Ctrl+Shift+l exec swaylock

  # Change keyboard layout
  $mod+Shift+Escape exec $HOME/scripts/kbd_input_sway

  # kill focused window
  $mod+Shift+c kill

  # Minimization
  $mod+m $minimize
  $mod+Shift+m $unminimize

  # Program launcher
  $alt+space exec $rofi_cmd
  $mod+r exec $rofi_cmd
  $mod+p exec $mailclient
  #$mod+d exec --no-startup-id i3-mailclient thunderbird
  $mod+Shift+p $mailclient

  # Calculator
  $mod+equal exec $calculator
  $mod+c exec $calculator
  XF86Calculator exec $calculator

  # Browser
  XF86HomePage exec $browser

  # Mail Client
  XF86Mail exec $mailclient

  # Screenshot
  --release Print exec $HOME/scripts/screenshot -f sway -c fullscreen
  --release Ctrl+Print exec $HOME/scripts/screenshot -f sway -c window
  $mod+Print exec $HOME/scripts/screenshot -f sway -c teiler

  # Searching the Web
  $mod+Shift+slash exec rofi-surfraw

  # Password Manager
  $mod+Ctrl+p exec rofi-pass

  # Browsing the filesystem
  $mod+Shift+f exec $filemanager

  # Scratchpad
  $mod+Shift+e exec $scratchpad

  # change focus
  $mod+h focus left
  $mod+j focus down
  $mod+k focus up
  $mod+l focus right

  # alternatively, you can use the cursor keys:
  $mod+Left focus left
  $mod+Down focus down
  $mod+Up focus up
  $mod+Right focus right

  # move focused window
  $mod+Shift+h move left
  $mod+Shift+j move down
  $mod+Shift+k move up
  $mod+Shift+l move right

  # move to another output
  $mod+Ctrl+h move container to output left
  $mod+Ctrl+l move container to output right
  $mod+Ctrl+Left move workspace to output left
  $mod+Ctrl+Right move workspace to output right

  # alternatively, you can use the cursor keys:
  $mod+Shift+Left move left
  $mod+Shift+Down move down
  $mod+Shift+Up move up
  $mod+Shift+Right move right

  # resize mode
  $mod+Shift+r mode "resize"

  # split
  # $mod+Shift+s split toggle

  # split in horizontal orientation
  # $mod+bar split h
  # $mod+backslash split h

  # split in vertical orientation
  # $mod+shift+minus split v

  # enter fullscreen mode for the focused container
  $mod+f fullscreen toggle

  # change container layout (stacked, tabbed, toggle split)
  # $mod+s layout stacking
  $mod+w layout tabbed
  $mod+e layout toggle split

  # toggle tiling / floating
  $mod+t floating toggle
  $mod+s sticky toggle
  $mod+b border toggle

  # change focus between tiling / floating windows
  $mod+space focus mode_toggle

  # focus the parent container
  $mod+a focus parent

  # focus the child container
  # $mod+d focus child

  # notifications
  $mod+n exec swaync-client -t
  $mod+ctrl+space exec swaync-client --hide-latest

  # Function Keys
  # --locked XF86Power exec "sh ~/.config/scripts/shutdown.sh"
  --locked XF86MonBrightnessDown exec "light -U 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob"
  --locked XF86MonBrightnessUp exec "light -A 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob"
  $mod+F4 exec "$HOME/.rofi/monitor_layout.sh"
  $mod+Shift+F4 exec "$HOME/.rofi/rofi-randr"
  --locked XF86AudioPlay exec "$HOME/scripts/bar/music -f sway toggle"
  $mod+XF86AudioPlay exec "clerk"
  # XF86AudioPlay with Ctrl to stop
  --locked Ctrl+XF86AudioPlay exec "$HOME/scripts/bar/music -f sway stop"
  # XF86AudioPrev to seek
  --locked XF86AudioPrev exec "$HOME/scripts/bar/music -f sway seek-"
  # XF86AudioPrev with Ctrl to previous track
  --locked Ctrl+XF86AudioPrev exec "$HOME/scripts/bar/music -f sway prev"
  # XF86AudioNext to seek
  --locked XF86AudioNext exec "$HOME/scripts/bar/music -f sway seek+"
  # XF86AudioNext with Ctrl to next track
  --locked Ctrl+XF86AudioNext exec "$HOME/scripts/bar/music -f sway next"
  --locked XF86AudioLowerVolume exec "$HOME/scripts/bar/music -f sway volume-"
  --locked XF86AudioRaiseVolume exec "$HOME/scripts/bar/music -f sway volume+"
  --locked XF86AudioMute exec "$HOME/scripts/bar/music -f sway mute"

  # switch to workspace
  $mod+tab workspace next
  $mod+shift+tab workspace prev
  # Workspace Switcher
  $mod+grave exec "$HOME/.rofi/i3_switch_workspace.sh"
  # bind keys from 1-0 to switch to specific workspace
  $mod+1 workspace $ws_terminal
  $mod+2 workspace $ws_dev
  $mod+3 workspace $ws_web
  $mod+4 workspace $ws_office
  $mod+5 workspace $ws_doc
  $mod+6 workspace $ws_files
  $mod+7 workspace $ws_vnc
  $mod+8 workspace $ws_vm
  $mod+9 workspace $ws_im
  $mod+0 workspace $ws_media

  # Switch Windows
  $alt+tab focus next
  $alt+shift+tab focus prev

  # move focused container to workspace
  $mod+Shift+grave exec "$HOME/.rofi/move_window_to_current"
  $mod+Shift+1 move container to workspace $ws_terminal
  $mod+Shift+2 move container to workspace $ws_dev
  $mod+Shift+3 move container to workspace $ws_web
  $mod+Shift+4 move container to workspace $ws_office
  $mod+Shift+5 move container to workspace $ws_doc
  $mod+Shift+6 move container to workspace $ws_files
  $mod+Shift+7 move container to workspace $ws_vnc
  $mod+Shift+8 move container to workspace $ws_vm
  $mod+Shift+9 move container to workspace $ws_im
  $mod+Shift+0 move container to workspace $ws_media
}

# resize window (you can also use the mouse for that)
mode "resize" {
  # These bindings trigger as soon as you enter the resize mode

  # Pressing left will shrink the window’s width.
  # Pressing right will grow the window’s width.
  # Pressing up will shrink the window’s height.
  # Pressing down will grow the window’s height.
  bindsym --to-code {
    h resize shrink width 10 px or 10 ppt
    j resize grow height 10 px or 10 ppt
    k resize shrink height 10 px or 10 ppt
    l resize grow width 10 px or 10 ppt

  # same bindings, but for the arrow keys
    Left resize shrink width 10 px or 10 ppt
    Down resize grow height 10 px or 10 ppt
    Up resize shrink height 10 px or 10 ppt
    Right resize grow width 10 px or 10 ppt

  # back to normal: Enter or Escape
    Return mode "default"
    Escape mode "default"
  }
}

