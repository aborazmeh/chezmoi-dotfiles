// Place your key bindings in this file to override the defaults
[
  {
    "key": "ctrl+shift+i",
    "command": "-emojisense.quickEmojitext",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+shift+down",
    "command": "cursorMove",
    "when": "editorTextFocus",
    "args": {
        "to": "nextBlankLine",
        "select": true
    }
  },
  {
      "key": "ctrl+shift+up",
      "command": "cursorMove",
      "when": "editorTextFocus",
      "args": {
          "to": "prevBlankLine",
          "select": true
      }
  }
]
